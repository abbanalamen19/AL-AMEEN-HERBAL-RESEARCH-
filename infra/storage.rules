rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() { return request.auth != null; }
    function role() { return isSignedIn() ? request.auth.token.role : 'public'; }
    function isContributor() {
      return role() in ['super_admin', 'researcher', 'practitioner', 'contributor'];
    }

    // Public can read published media; contributors can upload bounded images.
    match /media/{allPaths=**} {
      allow read: if true;
      allow write: if isContributor()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Identification uploads are user-scoped and short-lived.
    match /identify/{uid}/{file} {
      allow read, write: if isSignedIn() && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
